    },
    "layout_strategies": {
      "glass_panels": "Use slightly transparent backgrounds (bg-black/60) with blur to allow the city background to peek through.",
      "neon_borders": "Use 1px borders with low opacity (border-white/10) for structure, and glowing borders (border-primary/50) for active states.",
      "grid_system": "Use 'Bento' grids for dashboard widgets. Gap-4 or Gap-6.",
      "mobile_first": "All layouts must stack on mobile. Navigation shifts to bottom bar or hamburger menu."
    },
    "interactions": {
      "hover_effects": "Elements should lift (-translate-y-1) and glow on hover.",
      "gifting_animation": "When a gift is sent, it should appear center screen, scale up, and then fly to the streamer's avatar.",
      "combo_counter": "Display a large 'x2', 'x3' counter that shakes on each increment."
    },
    "accessibility": {
      "contrast": "Ensure text is always White on Dark backgrounds. Use light grey (Slate-300) for secondary text.",
      "focus_states": "Visible focus rings with primary color.",
      "reduced_motion": "Respect user preferences for reduced motion."
    }
  },
  "implementation_instructions": {
    "libraries": [
      "framer-motion",
      "lucide-react",
      "clsx",
      "tailwind-merge",
      "sonner"
    ],
    "setup_steps": [
      "Install required libraries: yarn add framer-motion lucide-react clsx tailwind-merge sonner",
      "Add the Google Fonts import to index.css or index.html",
      "Update tailwind.config.js with the new color palette and fonts",
      "Create a reusable 'GlassCard' component",
      "Create a 'NeonButton' component"
    ],
    "universal_guidelines": [
      "Avoid default 'shadcn' look. Customize radii to be smaller (rounded-md or rounded-sm) for a tech feel.",
      "Do NOT use pure black (#000000). Use #050511 for background.",
      "Use 'Orbitron' font for all Headings to give the Cyberpunk identity.",
      "Ensure all interactive elements have data-testid attributes."
    ]
  }
}
