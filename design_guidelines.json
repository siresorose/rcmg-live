{
  "design_system": {
    "identity": {
      "name": "RCMG Live",
      "aesthetic": "Dark Neon Cyberpunk Cityscape",
      "tone": "High Energy, futuristic, luxurious, gamified",
      "logo_url": "https://customer-assets.emergentagent.com/job_go-rcmg/artifacts/0aiiowdn_8130.jpg"
    },
    "colors": {
      "palette": {
        "primary": {
          "default": "#FF0033",
          "hover": "#CC0029",
          "glow": "0 0 20px rgba(255, 0, 51, 0.6)"
        },
        "secondary": {
          "default": "#00F0FF",
          "hover": "#00C0CC",
          "glow": "0 0 20px rgba(0, 240, 255, 0.6)"
        },
        "accent": {
          "purple": "#BD00FF",
          "green": "#00FF66",
          "gold": "#FFD700"
        },
        "background": {
          "main": "#050511",
          "surface": "#0F0F1A",
          "glass": "rgba(15, 15, 26, 0.6)"
        },
        "text": {
          "primary": "#FFFFFF",
          "secondary": "#94A3B8",
          "muted": "#64748B"
        },
        "status": {
          "success": "#00FF66",
          "error": "#FF0033",
          "warning": "#FFD700"
        }
      },
      "gradients": {
        "brand": "linear-gradient(135deg, #FF0033 0%, #BD00FF 100%)",
        "cyber": "linear-gradient(90deg, #00F0FF 0%, #BD00FF 100%)",
        "glass": "linear-gradient(180deg, rgba(255,255,255,0.05) 0%, rgba(255,255,255,0) 100%)"
      }
    },
    "typography": {
      "font_family": {
        "headings": "Orbitron, sans-serif",
        "body": "Inter, sans-serif",
        "mono": "JetBrains Mono, monospace"
      },
      "import_url": "https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Orbitron:wght@400;500;700;900&family=JetBrains+Mono&display=swap",
      "scale": {
        "h1": "text-5xl md:text-7xl font-black tracking-tight",
        "h2": "text-3xl md:text-5xl font-bold tracking-tight",
        "h3": "text-2xl md:text-3xl font-bold",
        "body_lg": "text-lg leading-relaxed",
        "body": "text-base leading-relaxed",
        "small": "text-sm text-slate-400"
      }
    },
    "spacing": {
      "container_padding": "p-4 md:p-8 lg:p-12",
      "section_gap": "gap-8 md:gap-16",
      "card_padding": "p-6"
    },
    "visual_enhancers": {
      "borders": {
        "default": "border border-white/10",
        "glow": "border border-primary/50 shadow-[0_0_15px_rgba(255,0,51,0.3)]"
      },
      "shadows": {
        "neon_red": "0 0 20px rgba(255, 0, 51, 0.4)",
        "neon_blue": "0 0 20px rgba(0, 240, 255, 0.4)",
        "glass": "0 8px 32px 0 rgba(0, 0, 0, 0.37)"
      },
      "effects": {
        "glassmorphism": "backdrop-blur-xl bg-black/40 border border-white/10",
        "scanlines": "background: repeating-linear-gradient(0deg, rgba(0,0,0,0.15) 0px, rgba(0,0,0,0.15) 1px, transparent 1px, transparent 2px)"
      }
    },
    "components": {
      "Button": {
        "variants": {
          "primary": "bg-primary text-white hover:bg-primary/90 shadow-[0_0_15px_rgba(255,0,51,0.4)] transition-all duration-300 hover:scale-105 font-orbitron tracking-wider clip-path-slant",
          "secondary": "bg-secondary/10 text-secondary border border-secondary/50 hover:bg-secondary/20 hover:shadow-[0_0_15px_rgba(0,240,255,0.4)] transition-all duration-300",
          "ghost": "hover:bg-white/10 text-white transition-colors"
        },
        "shape": "rounded-sm"
      },
      "Card": {
        "style": "bg-black/60 backdrop-blur-xl border border-white/10 rounded-xl overflow-hidden shadow-2xl"
      },
      "Input": {
        "style": "bg-black/40 border-white/20 text-white placeholder:text-white/30 focus:border-primary focus:ring-1 focus:ring-primary rounded-md"
      }
    },
